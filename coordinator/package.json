{
  "name": "@coordinator/ai-manager",
  "version": "0.1.0",
  "description": "A flexible AI Manager library with OpenRouter integration and tool handling",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "bun run --watch src/index.ts",
    "start": "bun run api:start",
    "test": "bun test",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src/**/*.ts",
    "prepublishOnly": "bun run build",
    "api:dev": "bun --watch src/api/server.ts",
    "api:start": "bun src/api/server.ts",
    "api:test": "bun run src/api/test-api.ts",
    "api:quick": "bun run src/api/quick-test.ts",
    "api:e2e": "bun run src/api/e2e-tests.ts",
    "api:e2e:watch": "bun --watch src/api/e2e-tests.ts"
  },
  "keywords": [
    "ai",
    "openrouter",
    "chat",
    "tools",
    "typescript"
  ],
  "author": "Coordinator",
  "license": "MIT",
  "dependencies": {
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "events": "^3.3.0",
    "express": "5.1.0",
    "helmet": "^7.0.0",
    "uuid": "^9.0.0",
    "ws": "^8.14.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "@types/express": "^4.17.17",
    "@types/ws": "^8.5.5",
    "@types/cors": "^2.8.13",
    "@types/compression": "^1.7.2",
    "@types/uuid": "^9.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/coordinator/ai-manager.git"
  },
  "bugs": {
    "url": "https://github.com/coordinator/ai-manager/issues"
  },
  "homepage": "https://github.com/coordinator/ai-manager#readme"
}