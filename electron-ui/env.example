# AI Manager API Configuration
# Copy this file to .env and fill in your values

# Required: Your OpenRouter API key
VITE_OPENROUTER_API_KEY=your-openrouter-api-key-here

# Optional: Default AI model (default: anthropic/claude-3-haiku)
VITE_DEFAULT_MODEL=anthropic/claude-3-haiku

# Optional: Maximum tokens per response (default: 4096)
VITE_MAX_TOKENS=4096

# Optional: Temperature for AI responses (default: 0.7)
VITE_TEMPERATURE=0.7

# Optional: Top P for AI responses (default: 1)
VITE_TOP_P=1 